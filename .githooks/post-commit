#!/bin/bash
# Auto-bump version based on conventional commit prefix.
# Runs after commit, amends it with bumped version.
# Enable: git config core.hooksPath .githooks

# Prevent recursive invocation during amend
[ "$SKIP_VERSION_BUMP" = "1" ] && exit 0

COMMIT_MSG=$(git log -1 --pretty=%s)
VERSION_FILE=".claude-plugin/plugin.json"

# Skip version bump commits and merges
case "$COMMIT_MSG" in
  "chore(release):"*|"Merge"*) exit 0 ;;
esac

# Determine bump type from conventional commit prefix
case "$COMMIT_MSG" in
  *"!"*":"*) BUMP="major" ;;
  "feat"*)   BUMP="minor" ;;
  *)         BUMP="patch" ;;
esac

# Extract current version
CURRENT=$(grep -o '"version": "[^"]*"' "$VERSION_FILE" | head -1 | grep -o '[0-9]\+\.[0-9]\+\.[0-9]\+')
[ -z "$CURRENT" ] && exit 0

IFS='.' read -r MAJOR MINOR PATCH <<< "$CURRENT"
case "$BUMP" in
  major) NEW="$((MAJOR+1)).0.0" ;;
  minor) NEW="$MAJOR.$((MINOR+1)).0" ;;
  patch) NEW="$MAJOR.$MINOR.$((PATCH+1))" ;;
esac

sed -i "0,/\"version\": \"$CURRENT\"/s//\"version\": \"$NEW\"/" "$VERSION_FILE"
git add "$VERSION_FILE"
SKIP_VERSION_BUMP=1 git commit --amend --no-edit --no-verify >/dev/null 2>&1

echo "Version bumped: $CURRENT → $NEW ($BUMP)"
